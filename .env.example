# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tennisadvisor"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Provider (Optional)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@tennisadvisor.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# App
# URL publique du site. En PRODUCTION (Netlify) DOIT valoir le domaine canonique
# pour que les images Open Graph / Twitter (partage social) ne pointent pas vers
# localhost (cf. Audit #2.1). En local, http://localhost:3000 est accepté mais
# le code force le domaine canonique dès qu'une valeur localhost est détectée.
# Prod : NEXT_PUBLIC_APP_URL="https://tennisstringadvisor.org"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Analytics — Google Analytics 4 (mesure du funnel, cf. Audit #0.1)
# ID de mesure GA4 ; fallback code = G-YSSLHJ5WYD si non défini.
NEXT_PUBLIC_GA_ID="G-YSSLHJ5WYD"

# Affiliation — Awin / Tennis-Point (cf. Audit #3.0)
# Activation SANS redéploiement : tant que ces 2 variables ne sont pas
# renseignées, les boutons « Voir le prix » pointent en direct (non tracké)
# vers tennis-point.fr. Dès qu'elles sont définies, les liens deviennent des
# deep-links Awin trackés (commission jusqu'à 9 %, cookie 30 j).
#
# NEXT_PUBLIC_AWIN_ID : ton Publisher/Affiliate ID Awin (après inscription Awin).
# NEXT_PUBLIC_AWIN_TENNISPOINT_MID : l'Advertiser ID (awinmid) de Tennis-Point FR
#   (visible dans Awin une fois le programme Tennis-Point rejoint/approuvé).
NEXT_PUBLIC_AWIN_ID=""
NEXT_PUBLIC_AWIN_TENNISPOINT_MID=""

# Premium Features
ENABLE_PREMIUM_FEATURES="true"
FREE_TRIAL_DAYS="7"
MAX_FREE_CONFIGURATIONS="3"